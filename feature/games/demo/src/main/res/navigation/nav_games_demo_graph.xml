<?xml version="1.0" encoding="utf-8"?>
<!--
    Граф демо-приложения игр. Destination'ы игр объявляются с теми же id,
    что и в графах основного приложения (@id/... из :core:ui), а action'ы
    игры («к результату», «назад к выбору») перенаправлены на экраны демо —
    поэтому код игр работает здесь без изменений.
-->
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_games_demo_graph"
    app:startDestination="@id/demoLauncherFragment">

    <fragment
        android:id="@+id/demoLauncherFragment"
        android:name="com.example.smartalarm.feature.games.demo.DemoLauncherFragment"
        android:label="fragment_demo_launcher">
        <action
            android:id="@+id/action_demoLauncherFragment_to_calcGameFragment2"
            app:destination="@id/calcGameFragment2" />
        <action
            android:id="@+id/action_demoLauncherFragment_to_memoryGameFragment2"
            app:destination="@id/memoryGameFragment2" />
        <action
            android:id="@+id/action_demoLauncherFragment_to_equationGameFragment2"
            app:destination="@id/equationGameFragment2" />
        <action
            android:id="@+id/action_demoLauncherFragment_to_sortingGameFragment2"
            app:destination="@id/sortingGameFragment2" />
        <action
            android:id="@+id/action_demoLauncherFragment_to_pairsGameFragment2"
            app:destination="@id/pairsGameFragment2" />
        <action
            android:id="@+id/action_demoLauncherFragment_to_sequenceGameFragment2"
            app:destination="@id/sequenceGameFragment2" />
        <action
            android:id="@+id/action_demoLauncherFragment_to_stroopGameFragment2"
            app:destination="@id/stroopGameFragment2" />
        <action
            android:id="@+id/action_demoLauncherFragment_to_oddoneoutGameFragment2"
            app:destination="@id/oddoneoutGameFragment2" />
        <action
            android:id="@+id/action_demoLauncherFragment_to_mazeGameFragment2"
            app:destination="@id/mazeGameFragment2" />
        <action
            android:id="@+id/action_demoLauncherFragment_to_anagramGameFragment2"
            app:destination="@id/anagramGameFragment2" />
        <action
            android:id="@+id/action_demoLauncherFragment_to_truefalseGameFragment2"
            app:destination="@id/truefalseGameFragment2" />
    </fragment>

    <fragment
        android:id="@id/calcGameFragment2"
        android:name="com.example.smartalarm.feature.games.calc.CalcGameFragment"
        android:label="fragment_calc_game">
        <action
            android:id="@id/action_calcGameFragment2_to_gameResultFragment2"
            app:destination="@id/demoResultFragment" />
        <action
            android:id="@id/action_calcGameFragment2_to_gameChoiceFragment"
            app:destination="@id/demoLauncherFragment"
            app:popUpTo="@id/demoLauncherFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@id/memoryGameFragment2"
        android:name="com.example.smartalarm.feature.games.memory.MemoryGameFragment"
